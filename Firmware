#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ST7789.h>

#define TFT_CS 16
#define TFT_DC 17
#define TFT_RST -1

Adafruit_ST7789 tft = Adafruit_ST7789(TFT_CS, TFT_DC, TFT_RST);

void setup() {
  Serial.begin(115200);

  SPI.begin(21, 13, 46, 16);

  tft.init(240, 240);
  tft.setRotation(2);
  tft.fillScreen(0x0000);
  
  tft.setCursor(20, 20);
  tft.setTextColor(0x07E0);
  tft.setTextSize(2);
  tft.println("FLIPHACK V1");
  tft.println("booting...");
}

void loop() {
  
}
